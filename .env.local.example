# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── AI Provider (pick ONE — cheapest first) ─────────────────────────────────
# AI_PROVIDER=ollama    # default if OLLAMA_BASE_URL is set → FREE (local)
# AI_PROVIDER=groq      # default if GROQ_API_KEY is set   → FREE tier
# AI_PROVIDER=anthropic # fallback                         → PAID

# ── Option 1: Ollama — ZERO COST, runs locally ────────────────────────────────
# Install: https://ollama.com  then: ollama pull llama3.1
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
# Good free models: llama3.1:8b (fast), llama3.1:70b (better), mistral, phi3

# ── Option 2: Groq — FREE tier (fast inference) ───────────────────────────────
# Sign up free: https://console.groq.com
# Free limits: 30 req/min, 14,400 tokens/min, 500K tokens/day
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile
# Other free Groq models: mixtral-8x7b-32768, gemma2-9b-it

# ── Option 3: Anthropic — Paid, highest quality ───────────────────────────────
# https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ─── Plaid (optional — for live bank feeds) ──────────────────────────────────
# Sign up free at https://plaid.com/docs
# PLAID_CLIENT_ID=
# PLAID_SECRET=
# PLAID_ENV=sandbox

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
