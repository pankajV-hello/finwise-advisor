# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── AI Provider ─────────────────────────────────────────────────────────────
# DEFAULT: Groq free tier — sign up at https://console.groq.com (takes 1 min)
# Free limits: 500K tokens/day · 30 req/min · no credit card needed
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=llama-3.2-11b-vision-preview

# ── Local Ollama — 100% free, runs on your Mac ────────────────────────────────
# Setup: brew install ollama && ollama pull llama3.1 && ollama serve
# Uncomment to use Ollama instead of Groq:
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b
# OLLAMA_VISION_MODEL=llava          ← for document/image extraction
# AI_PROVIDER=ollama                 ← force Ollama even if GROQ_API_KEY is set

# ── Anthropic — optional, paid, best quality ──────────────────────────────────
# Only needed if you set AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# AI_PROVIDER=anthropic

# ─── Plaid (optional — live bank feeds) ──────────────────────────────────────
# Sign up free at https://dashboard.plaid.com/signup
# PLAID_CLIENT_ID=
# PLAID_SECRET=
# PLAID_ENV=sandbox

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
